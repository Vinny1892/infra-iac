#!/bin/bash

sudo curl -sfL https://get.k3s.io | sh -s - server --write-kubeconfig-mode 644 \
    --disable=traefik \
    --disable-cloud-controller \
    --token '${token}' \
    --datastore-endpoint='postgres://${username}:${password}@${hostname}:${port}/${database_name}' \
    --tls-san '${dns_name}'