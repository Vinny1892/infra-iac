      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "2621847549",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::036785638465:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/0743CBBB9284F2C5A7C3C070C1C99F6E\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.us-east-1.amazonaws.com/id/0743CBBB9284F2C5A7C3C070C1C99F6E:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.us-east-1.amazonaws.com/id/0743CBBB9284F2C5A7C3C070C1C99F6E:sub\": \"system:serviceaccount:kube-system:ebs-csi-controller-sa\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":\"sts:AssumeRoleWithWebIdentity\",\"Principal\":{\"Federated\":\"arn:aws:iam::036785638465:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/0743CBBB9284F2C5A7C3C070C1C99F6E\"},\"Condition\":{\"StringEquals\":{\"oidc.eks.us-east-1.amazonaws.com/id/0743CBBB9284F2C5A7C3C070C1C99F6E:aud\":\"sts.amazonaws.com\",\"oidc.eks.us-east-1.amazonaws.com/id/0743CBBB9284F2C5A7C3C070C1C99F6E:sub\":\"system:serviceaccount:kube-system:ebs-csi-controller-sa\"}}}]}",
